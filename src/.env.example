# Comma-separated list of allowed frontend origins
# Example: https://qoscollab.app,https://staging.qoscollab.app
ALLOWED_ORIGINS=https://your-frontend-domain.com

# Model artifact paths (relative to service root)
MODEL_PATH=qos_model.pkl
SCALER_PATH=scaler.pkl

# Render injects PORT automatically
PORT=8000

# Frontend ML API URL for direct prediction calls (optional).
# Example: http://localhost:8000/predict
VITE_ML_API_URL=
