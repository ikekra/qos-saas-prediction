# Frontend app environment
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Optional direct ML API URL. Most prediction flows use the Supabase
# `predict-qos` Edge Function instead, so this can be left blank.
VITE_ML_API_URL=

# Feature flags
VITE_PAYMENT_ENABLED=false
VITE_TOKEN_POLL_INTERVAL_MS=60000

# Frontend token cost display defaults
VITE_TOKEN_COST_LATENCY=5
VITE_TOKEN_COST_THROUGHPUT=10
VITE_TOKEN_COST_UPTIME=8
VITE_TOKEN_COST_FULL_REPORT=20
VITE_TOKEN_COST_HISTORICAL_ANALYSIS=25
VITE_TOKEN_COST_ANOMALY_SCAN=15

# Backend / ML service environment (set these in Render for the Python service,
# not in the frontend .env file)
# ALLOWED_ORIGINS=https://your-frontend-domain.com
# MODEL_PATH=qos_model.pkl
# SCALER_PATH=scaler.pkl
# PORT=8000
